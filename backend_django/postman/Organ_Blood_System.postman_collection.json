{
  "info": {
    "name": "Organ Blood System API",
    "description": "Postman collection for the Django backend APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "fb3c26bf-b79d-4d36-93f7-6bfdf8f36ec9"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"acceptor1\",\n  \"email\": \"acceptor1@example.com\",\n  \"phone\": \"9999999991\",\n  \"password\": \"StrongPass123\",\n  \"user_type\": \"ACCEPTOR\",\n  \"city\": \"Chennai\",\n  \"state\": \"TN\"\n}"
            },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.tokens) {",
                  "  pm.environment.set('access_token', res.data.tokens.access);",
                  "  pm.environment.set('refresh_token', res.data.tokens.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"acceptor1\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/token/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Requests",
      "item": [
        {
          "name": "Create Blood Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"blood_group\": \"O+\",\n  \"units_needed\": 2,\n  \"required_date\": \"2026-03-01\",\n  \"urgency\": \"HIGH\",\n  \"city\": \"Chennai\",\n  \"state\": \"TN\",\n  \"notes\": \"Emergency\"\n}"
            },
            "url": "{{base_url}}/api/requests/blood"
          }
        },
        {
          "name": "Create Organ Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organ_type\": \"kidney\",\n  \"required_date\": \"2026-03-10\",\n  \"urgency\": \"CRITICAL\",\n  \"city\": \"Chennai\",\n  \"state\": \"TN\",\n  \"notes\": \"ICU case\"\n}"
            },
            "url": "{{base_url}}/api/requests/organ"
          }
        },
        {
          "name": "My Requests",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/requests/my"
          }
        },
        {
          "name": "Request Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/requests/{{request_id}}"
          }
        },
        {
          "name": "Cancel Request",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\"\n}"
            },
            "url": "{{base_url}}/api/requests/{{request_id}}"
          }
        }
      ]
    },
    {
      "name": "Donors",
      "item": [
        {
          "name": "Get/Upsert Donor Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"blood_group\": \"O+\",\n  \"organ_willing\": true,\n  \"organ_types\": [\"kidney\"],\n  \"city\": \"Chennai\",\n  \"state\": \"TN\",\n  \"medical_notes\": \"Fit for donation\"\n}"
            },
            "url": "{{base_url}}/api/donors/profile"
          }
        },
        {
          "name": "Update Availability",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"availability_status\": \"AVAILABLE\"\n}"
            },
            "url": "{{base_url}}/api/donors/availability"
          }
        },
        {
          "name": "My Matches",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/donors/matches"
          }
        },
        {
          "name": "Respond To Match",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"response\": \"ACCEPTED\"\n}"
            },
            "url": "{{base_url}}/api/donors/matches/{{match_id}}/respond"
          }
        }
      ]
    },
    {
      "name": "Matching & Search",
      "item": [
        {
          "name": "Run Matching",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/matching/run?request_id={{request_id}}"
          }
        },
        {
          "name": "Search Donors Blood",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/search/donors?type=blood&blood_group=O%2B&city=Chennai"
          }
        },
        {
          "name": "Search Donors Organ",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/search/donors?type=organ&organ=kidney&city=Chennai"
          }
        }
      ]
    },
    {
      "name": "Hospital",
      "item": [
        {
          "name": "Hospital Requests",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/hospital/requests"
          }
        },
        {
          "name": "Pending Verifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/hospital/verifications/pending"
          }
        },
        {
          "name": "Update Donor Verification",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verification_status\": \"VERIFIED\"\n}"
            },
            "url": "{{base_url}}/api/hospital/verifications/{{donor_id}}"
          }
        },
        {
          "name": "Update Request Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\",\n  \"notes\": \"Approved by hospital\"\n}"
            },
            "url": "{{base_url}}/api/hospital/requests/{{request_id}}/status"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "My Notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/notifications"
          }
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/notifications/{{notification_id}}/read"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/admin/audit"
          }
        },
        {
          "name": "Summary Report",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/admin/reports/summary"
          }
        },
        {
          "name": "Admin Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/admin/users"
          }
        },
        {
          "name": "Update Admin User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": true\n}"
            },
            "url": "{{base_url}}/api/admin/users/{{user_id}}"
          }
        },
        {
          "name": "Admin Hospitals",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/admin/hospitals"
          }
        },
        {
          "name": "Update Admin Hospital",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approval_status\": \"APPROVED\"\n}"
            },
            "url": "{{base_url}}/api/admin/hospitals/{{hospital_id}}"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "request_id", "value": "1" },
    { "key": "match_id", "value": "1" },
    { "key": "donor_id", "value": "1" },
    { "key": "notification_id", "value": "1" },
    { "key": "user_id", "value": "1" },
    { "key": "hospital_id", "value": "1" }
  ]
}
